# ============================================================
# FastLink Bot — production environment template
#
# This file is committed to the repository.
# It is used by GitHub Actions during deployment:
#
#   envsubst < .env.production.template > .env
#
# All ${VAR} placeholders are substituted during deployment
# from GitHub Environment secrets and variables.
# Derived values (DATABASE_URL, REDIS_URL_*) are assembled here
# from individual environment secrets and variables — do not add them separately.
#
# Rules:
#   - Do NOT put real secrets in this file.
#   - Keep in sync with settings_schema.py and .env.example.
#   - Production-specific defaults are hardcoded here (no secret needed).
# ============================================================


# ============================================================
# RUNTIME MODE
# ============================================================
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO


# ============================================================
# TELEGRAM BOT
# ============================================================
BOT_TOKEN=${BOT_TOKEN}
OWNER_TELEGRAM_ID=${OWNER_TELEGRAM_ID}
BOT_PARSE_MODE=HTML


# ============================================================
# WEBHOOK / HTTP
# ============================================================
USE_WEBHOOK=true
SKIP_WEBHOOK_REGISTRATION=false
WEBHOOK_BASE_URL=https://fastlinkproject.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=${WEBHOOK_SECRET}
HEALTHCHECK_PATH=/health
HTTP_HOST=0.0.0.0
HTTP_PORT=8080


# ============================================================
# POSTGRESQL
# ============================================================
POSTGRES_DB=${POSTGRES_DB}
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# Assembled from individual secrets — not stored separately.
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}


# ============================================================
# REDIS
# ============================================================
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_FSM_DB=1
REDIS_CACHE_DB=2
REDIS_RATE_LIMIT_DB=3
REDIS_PAYMENT_DB=4
REDIS_MARZBAN_TOKEN_DB=5

# Assembled from individual secrets — not stored separately.
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_URL_FSM=redis://:${REDIS_PASSWORD}@redis:6379/1
REDIS_URL_CACHE=redis://:${REDIS_PASSWORD}@redis:6379/2
REDIS_URL_RATE_LIMIT=redis://:${REDIS_PASSWORD}@redis:6379/3
REDIS_URL_PAYMENT=redis://:${REDIS_PASSWORD}@redis:6379/4
REDIS_URL_MARZBAN_TOKEN=redis://:${REDIS_PASSWORD}@redis:6379/5


# ============================================================
# ADMIN / SESSION
# ============================================================
ADMIN_SESSION_TTL_SECONDS=28800


# ============================================================
# MARZBAN API
# ============================================================
MARZBAN_API_BASE=http://host.docker.internal:8000/api
MARZBAN_USERNAME=${MARZBAN_USERNAME}
MARZBAN_PASSWORD=${MARZBAN_PASSWORD}
MARZBAN_TIMEOUT_SECONDS=10


# ============================================================
# METRICS
# ============================================================
METRICS_URL=https://fastlinkproject.com/metrics
METRICS_TOKEN=${METRICS_TOKEN}


# ============================================================
# LANGUAGE / I18N
# ============================================================
DEFAULT_LANGUAGE=ru
FEATURE_I18N_ENABLED=false


# ============================================================
# YOOKASSA
# ============================================================
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=


# ============================================================
# FEATURE FLAGS
# ============================================================
FEATURE_ADMIN_ENABLED=true
FEATURE_PAYMENTS_ENABLED=false
FEATURE_REFUNDS_ENABLED=false
