# =========================
# FastLink Bot configuration template
# Copy to .env.local for local development
# Copy to .env on staging/production
# Never commit real secrets
# =========================

# App
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO

# Telegram bot
BOT_TOKEN=CHANGE_ME_BOT_TOKEN
BOT_PARSE_MODE=HTML
OWNER_TELEGRAM_ID=CHANGE_ME_TELEGRAM_ID

# Webhook / HTTP
# Local:      USE_WEBHOOK=false
# Production: USE_WEBHOOK=true, set real domain in WEBHOOK_BASE_URL
USE_WEBHOOK=false
SKIP_WEBHOOK_REGISTRATION=false
WEBHOOK_BASE_URL=https://example.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET_MIN_32
HEALTHCHECK_PATH=/health
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# PostgreSQL
POSTGRES_DB=fastlink
POSTGRES_USER=fastlinkuser
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

DATABASE_URL=postgresql+asyncpg://fastlinkuser:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/fastlink
DATABASE_URL_SYNC=postgresql://fastlinkuser:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/fastlink

# SQLAlchemy pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

REDIS_DB=0
REDIS_FSM_DB=1
REDIS_CACHE_DB=2
REDIS_RATE_LIMIT_DB=3
REDIS_PAYMENT_DB=4
REDIS_MARZBAN_TOKEN_DB=5

REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
REDIS_URL_FSM=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1
REDIS_URL_CACHE=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/2
REDIS_URL_RATE_LIMIT=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/3
REDIS_URL_PAYMENT=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/4
REDIS_URL_MARZBAN_TOKEN=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/5

# Redis TTL / locks
ADMIN_SESSION_TTL_SECONDS=28800
PAYMENT_IDEMPOTENCY_TTL_SECONDS=86400
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=86400
SCHEDULER_LOCK_TTL_SECONDS=300
MARZBAN_TOKEN_TTL_SECONDS=82800

# Throttling
THROTTLE_GLOBAL_LIMIT=3
THROTTLE_GLOBAL_WINDOW_SECONDS=1
THROTTLE_GLOBAL_COOLDOWN_SECONDS=30
THROTTLE_PAYMENT_LIMIT=1
THROTTLE_PAYMENT_WINDOW_SECONDS=1
THROTTLE_PAYMENT_COOLDOWN_SECONDS=60

# Marzban API
# Local:      MARZBAN_API_BASE=http://host.docker.internal:8000/api
# Production: external Marzban address
MARZBAN_API_BASE=http://host.docker.internal:8000/api
MARZBAN_USERNAME=CHANGE_ME_MARZBAN_USERNAME
MARZBAN_PASSWORD=CHANGE_ME_MARZBAN_PASSWORD
MARZBAN_TIMEOUT_SECONDS=10

# Metrics
METRICS_URL=https://example.com/metrics
METRICS_TOKEN=CHANGE_ME_METRICS_TOKEN
METRICS_TIMEOUT_SECONDS=5

# Default language / i18n
DEFAULT_LANGUAGE=ru
FEATURE_I18N_ENABLED=false

# Default server metadata
DEFAULT_SERVER_NAME=Finland
DEFAULT_SERVER_COUNTRY_CODE=FI
DEFAULT_SERVER_COUNTRY_NAME=Finland
DEFAULT_SERVER_EMOJI=🇫🇮
DEFAULT_SERVER_INBOUND_TAG=VLESS TCP REALITY

# VPN / subscription UX
SUBSCRIPTION_PROFILE_TITLE=FastLink VPN
SUPPORT_BOT_URL=
SUPPORT_CHAT_URL=
SUPPORT_CONTACT_TEXT=Напишите в поддержку
SUBSCRIPTION_UPDATE_INTERVAL_HOURS=12

# Payments / YooKassa
PAYMENT_PROVIDER_DEFAULT=yookassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://example.com
YOOKASSA_CURRENCY=RUB

# Refunds
REFUNDS_ENABLED=false
REFUND_REVIEW_WINDOW_HOURS=24

# Notifications / scheduler
NOTIFY_EXPIRING_3D_ENABLED=true
NOTIFY_EXPIRING_1D_ENABLED=true
NOTIFY_TRAFFIC_80_ENABLED=true
NOTIFY_TRAFFIC_95_ENABLED=true
NOTIFY_TRAFFIC_100_ENABLED=true

JOB_EXPIRE_SUBSCRIPTIONS_ENABLED=true
JOB_SYNC_TRAFFIC_ENABLED=true
JOB_NOTIFY_EXPIRING_ENABLED=true
JOB_NOTIFY_TRAFFIC_ENABLED=true
JOB_REFRESH_MARZBAN_TOKENS_ENABLED=true

JOB_EXPIRE_SUBSCRIPTIONS_INTERVAL_MINUTES=5
JOB_SYNC_TRAFFIC_INTERVAL_MINUTES=30
JOB_NOTIFY_TRAFFIC_INTERVAL_MINUTES=30
JOB_NOTIFY_EXPIRING_HOUR_UTC=10
JOB_REFRESH_MARZBAN_TOKENS_INTERVAL_HOURS=23

# Alerting
ALERTING_ENABLED=true
ALERTING_RATE_LIMIT_SECONDS=300
CRITICAL_ERROR_ALERTS_ENABLED=true
WEBHOOK_ALERTS_ENABLED=true
MARZBAN_ALERTS_ENABLED=true
SCHEDULER_ALERTS_ENABLED=true

# Backup / restore
BACKUP_ENABLED=false
BACKUP_SCHEDULE_CRON=0 3 * * *
BACKUP_TMP_DIR=/tmp
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=3

# Cloudflare R2
R2_ENABLED=false
R2_ENDPOINT_URL=https://CHANGE_ME.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=CHANGE_ME_R2_ACCESS_KEY
R2_SECRET_ACCESS_KEY=CHANGE_ME_R2_SECRET
R2_BUCKET=fastlink-backups

# Backblaze B2 fallback
B2_ENABLED=false
B2_ENDPOINT_URL=https://s3.CHANGE_ME.backblazeb2.com
B2_ACCESS_KEY_ID=CHANGE_ME_B2_KEY_ID
B2_SECRET_ACCESS_KEY=CHANGE_ME_B2_SECRET
B2_BUCKET=fastlink-backups-b2

# Feature flags
FEATURE_ADMIN_ENABLED=true
FEATURE_PAYMENTS_ENABLED=false
FEATURE_REFUNDS_ENABLED=false
FEATURE_METRICS_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_QR_ENABLED=true
FEATURE_SUPPORT_ENABLED=true
FEATURE_MULTI_SERVER_ENABLED=true
FEATURE_MULTI_TARIFF_ENABLED=true
