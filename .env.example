# ============================================================
# FastLink Bot — environment template
# Aligned with config.py (pydantic-settings v2, alias=VAR_NAME)
#
# Usage:
#   Local development : cp .env.example .env.local
#   VPS / production  : cp .env.example .env
#
# Rules:
#   - Do NOT commit .env or .env.local (both are in .gitignore).
#   - Keep this file in sync with config.py.
#   - Add a variable here only when it is added to config.py.
#   - Derived DSN strings (DATABASE_URL, REDIS_URL_*) must stay
#     consistent with the individual credential variables above them.
#     If you change POSTGRES_PASSWORD — update DATABASE_URL too.
# ============================================================


# ============================================================
# RUNTIME MODE
# ============================================================
# APP_ENV controls the runtime profile:
#   development  →  local dev, polling mode, mock integrations optional
#   production   →  VPS, webhook mode, real integrations
#   test         →  automated tests
APP_ENV=development

# Enable verbose output. Set true only for active debugging.
APP_DEBUG=false

# Structlog level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ============================================================
# TELEGRAM BOT
# ============================================================
# Obtain from @BotFather. Use a separate bot for dev and prod.
BOT_TOKEN=CHANGE_ME_BOT_TOKEN

# Your personal Telegram numeric ID (integer).
# Get it from @userinfobot. Used to bootstrap the first superadmin.
OWNER_TELEGRAM_ID=000000000

# Message parse mode passed to aiogram DefaultBotProperties.
# Default in config.py is HTML — only set this if you change it.
# BOT_PARSE_MODE=HTML


# ============================================================
# WEBHOOK / HTTP
# ============================================================
# --- Local development ---
# Typical local setup:
#   USE_WEBHOOK=false         → bot runs via polling, no HTTP server needed
#   WEBHOOK_BASE_URL          → can be left as placeholder when webhook disabled
#
# --- Production / VPS ---
# Typical production setup:
#   USE_WEBHOOK=true
#   WEBHOOK_BASE_URL=https://fastlinkproject.com
#   WEBHOOK_SECRET must be a real random string (openssl rand -hex 32)

USE_WEBHOOK=false

# When true, bot starts without registering the webhook with Telegram.
# Useful if Nginx / Telegram side is not yet ready.
SKIP_WEBHOOK_REGISTRATION=false

# Public HTTPS base URL (no trailing slash).
WEBHOOK_BASE_URL=https://example.com

# Webhook path. Nginx proxies /webhook → 127.0.0.1:8080/webhook
WEBHOOK_PATH=/webhook

# Secret token Telegram sends in X-Telegram-Bot-Api-Secret-Token header.
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# Internal health path served by the bot HTTP server.
# Default in config.py is /health — only set this if you change it.
# HEALTHCHECK_PATH=/health

# Bot HTTP bind address and port (inside container / app runtime).
# Default in config.py: 0.0.0.0 / 8080 — only override if needed.
# HTTP_HOST=0.0.0.0
# HTTP_PORT=8080


# ============================================================
# POSTGRESQL
# ============================================================
POSTGRES_DB=fastlink
POSTGRES_USER=fastlinkuser
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Async DSN — used by SQLAlchemy (asyncpg) at runtime.
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above.
# Hostname "postgres" = Docker Compose service name.
DATABASE_URL=postgresql+asyncpg://fastlinkuser:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/fastlink

# Sync DSN — used by Alembic for migrations (psycopg2).
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above.
DATABASE_URL_SYNC=postgresql://fastlinkuser:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/fastlink


# ============================================================
# REDIS
# ============================================================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Hostname "redis" = Docker Compose service name.
REDIS_HOST=redis
REDIS_PORT=6379

# Logical database allocation:
#   0  main / default
#   1  FSM   (aiogram RedisStorage)
#   2  cache
#   3  rate limiting / throttling
#   4  payment idempotency
#   5  Marzban token cache
#   6  taskqueue (ARQ)
REDIS_DB=0
REDIS_FSM_DB=1
REDIS_CACHE_DB=2
REDIS_RATE_LIMIT_DB=3
REDIS_PAYMENT_DB=4
REDIS_MARZBAN_TOKEN_DB=5
REDIS_TASKQUEUE_DB=6

# Full Redis DSNs — each must match REDIS_PASSWORD / REDIS_HOST / REDIS_PORT above.
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
REDIS_URL_FSM=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1
REDIS_URL_CACHE=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/2
REDIS_URL_RATE_LIMIT=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/3
REDIS_URL_PAYMENT=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/4
REDIS_URL_MARZBAN_TOKEN=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/5
REDIS_URL_TASKQUEUE=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/6


# ============================================================
# ADMIN / SESSION
# ============================================================
# Admin session TTL in Redis (seconds). Default: 28800 = 8 hours.
ADMIN_SESSION_TTL_SECONDS=28800


# ============================================================
# MARZBAN API
# ============================================================
# FastLink reaches Marzban via host.docker.internal because
# Marzban runs in host-network mode and FastLink runs in bridge (bot-net).
# Production: http://host.docker.internal:8000/api
# Local dev (WSL2 / Docker Desktop): same, or use host IP.
MARZBAN_API_BASE=http://host.docker.internal:8000/api
MARZBAN_USERNAME=CHANGE_ME_MARZBAN_USERNAME
MARZBAN_PASSWORD=CHANGE_ME_MARZBAN_PASSWORD

# HTTP client timeout for Marzban API calls (seconds).
# Default in config.py is 10 — only set this if you need to change it.
# MARZBAN_TIMEOUT_SECONDS=10


# ============================================================
# METRICS
# ============================================================
# metrics-agent listens on 127.0.0.1:9100, Nginx proxies /metrics there.
# Production example: https://fastlinkproject.com/metrics
METRICS_URL=https://example.com/metrics

# Bearer token for the metrics endpoint.
# Must match METRICS_TOKEN in /opt/metrics-agent/.env on the VPS.
# Generate: openssl rand -hex 32
METRICS_TOKEN=CHANGE_ME_METRICS_TOKEN


# ============================================================
# CRYPTO / MASTER KEY
# ============================================================
# Master key for application-level encryption (servers.apitoken, servers.metricstoken).
# Must be a 32-byte random value, encoded as hex.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FASTLINK_CRYPTO_MASTER_KEY=CHANGE_ME_FASTLINK_CRYPTO_MASTER_KEY


# ============================================================
# LANGUAGE / I18N
# ============================================================
DEFAULT_LANGUAGE=ru

# Enable multi-language support (not implemented in v1).
FEATURE_I18N_ENABLED=false


# ============================================================
# YOOKASSA
# ============================================================
# Leave empty until payments are enabled (Phase 4+).
# Obtain credentials at https://yookassa.ru/my/shop-settings/integration
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=


# ============================================================
# FEATURE FLAGS
# ============================================================
# Disable features that are not yet implemented to keep the bot stable.
FEATURE_ADMIN_ENABLED=true
FEATURE_PAYMENTS_ENABLED=false
FEATURE_REFUNDS_ENABLED=false
